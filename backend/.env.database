# PostgreSQL Database Configuration
DATABASE_URL=postgresql://gridify:gridify_password@postgres:5432/gridify

# Optional: For local development when running PostgreSQL separately
# DATABASE_URL=postgresql://gridify:gridify_password@localhost:5432/gridify

# Database settings
SQL_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Connection timeout (seconds)
DATABASE_CONNECT_TIMEOUT=10
